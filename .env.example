# Supabase (required for /login auth)
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Use either the anon key or the publishable key:
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Recommended for new signups: service role key (bypasses RLS). Without it, new user/company
# rows may not be created (RLS can block inserts). Used in auth callback and onboarding.
# Get it from: https://supabase.com/dashboard/project/_/settings/api (secret key)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# For Google OAuth: enable Google in Supabase Dashboard → Authentication → Providers
# and add your site URL + http://localhost:3000/auth/callback to Redirect URLs.
