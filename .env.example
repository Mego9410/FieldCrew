# Supabase (required for /login auth)
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Use either the anon key or the publishable key:
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Recommended for new signups: service role key (bypasses RLS). Without it, new user/company
# rows may not be created (RLS can block inserts). Used in auth callback and onboarding.
# Get it from: https://supabase.com/dashboard/project/_/settings/api (secret key)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# For Google OAuth: enable Google in Supabase Dashboard → Authentication → Providers
# and add your site URL + http://localhost:3000/auth/callback to Redirect URLs.

# Stripe (subscriptions, checkout, webhooks)
# Get keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook signing secret: from Stripe CLI (stripe listen) for local, or from Dashboard → Webhooks for production
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs for monthly plans (Starter $49, Growth $89, Pro $149) from Stripe Dashboard → Products
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_PRO=price_...

# Base URL for Stripe Checkout redirects (success/cancel). Optional: defaults to request origin.
# Local: http://localhost:3000  |  Vercel: https://your-app.vercel.app
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: separate origin for admin impersonation so it doesn't replace your admin session.
# Set this to a different domain/subdomain that serves the same app (same Supabase project).
# Example: https://imp.getfieldcrew.com
# IMPERSONATION_APP_URL=https://imp.getfieldcrew.com

# Security (2FA)
# Base64-encoded 32 bytes key used to encrypt TOTP secrets at rest (AES-256-GCM).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOTP_ENCRYPTION_KEY=base64-32-bytes

# Supabase Storage
# Bucket for owner avatar uploads (must exist in Supabase Storage).
AVATAR_BUCKET=avatars
